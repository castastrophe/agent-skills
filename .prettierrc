{
	"tabWidth": 4,
	"useTabs": true,
  "trailingComma": "es5",
	"overrides": [
    {
      "files": "package.json",
      "options": {
        "tabWidth": 2,
        "useTabs": false
      },
      "plugins": [
        "prettier-plugin-packagejson"
      ]
    },
    {
      "files": ".github/**/*.yml",
      "options": {
        "parser": "yaml",
        "tabWidth": 4,
        "useTabs": false
      }
    }
  ]
}
