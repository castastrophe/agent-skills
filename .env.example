# .env.example — The templated list of required environment variables for this project.
# To generate a new .env file, run: `yarn envoy`
# You do not have to manually edit the .env file, envoy will do it for you.
# NEVER commit .env to version control.

# --- Anthropic ---
# Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# --- GitHub ---
# GitHub personal access token (for MCP GitHub server)
GITHUB_TOKEN=

# --- NPM ---
# Your NPM token (for publishing to npm)
NPM_TOKEN=

# --- Session & Security ---
# GitHub username (used by CI scripts for credential context)
GITHUB_USER=
